# ──────────────────────────────────────────────────────────────────────────────
# ExpenseTracking — environment variables
# Copy this file to .env and fill in the values for your local setup.
# Variables prefixed with VITE_ are exposed to the browser bundle.
# ──────────────────────────────────────────────────────────────────────────────

# Google Drive sync (optional — leave blank to hide the Drive section in Settings)
#
# Setup steps:
#   1. Go to https://console.cloud.google.com → APIs & Services → Credentials
#   2. Create an OAuth 2.0 Client ID  →  Application type: Web application
#   3. Authorized JavaScript origins:   http://localhost:5173  (and your prod URL)
#   4. Authorized redirect URIs:        http://localhost:5173/oauth-callback
#                                       https://<your-prod-domain>/oauth-callback
#                                       https://<your-github-user>.github.io/<repo-name>/oauth-callback
#   5. Enable the Google Drive API for the project
#   6. Paste the Client ID and Client Secret below
#      ⚠ The client secret is bundled in the JS. Acceptable for personal/private apps.
#        For a public app, proxy the token exchange through a backend.
#
VITE_GOOGLE_CLIENT_ID=
# Required for token exchange (Authorization Code + PKCE flow)
VITE_GOOGLE_CLIENT_SECRET=

# Optional: force an exact OAuth redirect URI if your runtime origin differs
# (for example when using a custom host/port or reverse proxy).
# If omitted, the app uses: <window.location.origin>/oauth-callback
VITE_GOOGLE_REDIRECT_URI=
